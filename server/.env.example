# --- Server ---
PORT=8787
# Public origin the editor is served from (used for post-login redirect + cookie scope).
APP_BASE_URL=http://localhost:3000
# Path the user lands on after a successful login.
POST_LOGIN_PATH=/edit
NODE_ENV=development

# Serve the built static editor from this same process (single port behind a
# reverse proxy). FRONTEND_DIR defaults to ../docs relative to server/.
SERVE_FRONTEND=false
# FRONTEND_DIR=/opt/mermaid-live-editor/docs

# --- Database (PostgreSQL 15+) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mermaid_editor?schema=public

# --- App session JWT (httpOnly cookie) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
# Session lifetime in seconds (rolling). 3600 = 1 hour.
SESSION_TTL_SECONDS=3600

# --- Microsoft Entra ID (Azure AD) OIDC PKCE ---
# These are the BOOTSTRAP fallback. They let the first admin sign in before any
# config is saved via the Integrations UI. Once an admin saves Entra config in
# the app, the stored config overrides these values. All optional.
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=your-client-secret
# Must exactly match the redirect URI registered on the Entra app registration.
ENTRA_REDIRECT_URI=http://localhost:8787/api/auth/callback

# --- Admin allowlist ---
# Comma-separated emails allowed to edit integration settings (e.g. the Entra
# SSO config) from the Integrations page. Env-only by design.
ADMIN_EMAILS=admin@example.com

# --- MCP API access ---
# Static token for non-interactive clients (the MCP server under mcp/). A request
# with `Authorization: Bearer <MCP_API_TOKEN>` authenticates as MCP_API_EMAIL.
# Leave unset/empty to disable. Generate with:
#   node -e "console.log('mle_pat_' + require('crypto').randomBytes(32).toString('base64url'))"
MCP_API_TOKEN=
# The existing user MCP-token requests act as. Defaults to the first ADMIN_EMAILS
# entry. That user must have signed in once so their account row exists.
MCP_API_EMAIL=admin@example.com
