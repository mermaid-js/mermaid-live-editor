# --- Server ---
PORT=8787
# Public origin the editor is served from (used for post-login redirect + cookie scope).
APP_BASE_URL=http://localhost:3000
# Path the user lands on after a successful login.
POST_LOGIN_PATH=/edit
NODE_ENV=development

# Serve the built static editor from this same process (single port behind a
# reverse proxy). FRONTEND_DIR defaults to ../docs relative to server/.
SERVE_FRONTEND=false
# FRONTEND_DIR=/opt/mermaid-live-editor/docs

# --- Database (PostgreSQL 15+) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mermaid_editor?schema=public

# --- App session JWT (httpOnly cookie) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string
# Session lifetime in seconds (rolling). 3600 = 1 hour.
SESSION_TTL_SECONDS=3600

# --- Microsoft Entra ID (Azure AD) OIDC PKCE ---
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=your-client-secret
# Must exactly match the redirect URI registered on the Entra app registration.
ENTRA_REDIRECT_URI=http://localhost:8787/api/auth/callback
