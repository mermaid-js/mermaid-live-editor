{
  "extends": [
    "config:base",
    ":rebaseStalePrs",
    "group:allNonMajor",
    "schedule:earlyMondays",
    ":automergeMinor",
    ":automergeTesters",
    ":automergeLinters",
    ":automergeTypes",
    ":automergePatch"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["mermaid"],
      "matchPackagePatterns": ["^@mermaid-js/"],
      "groupName": "Mermaid packages",
      "schedule": ["at any time"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    }
  ],
  "dependencyDashboard": true,
  "major": {
    "dependencyDashboardApproval": true
  },
  "dependencyDashboardAutoclose": true,
  "rangeStrategy": "bump"
}
